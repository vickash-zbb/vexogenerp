RewriteEngine On

# Block direct access to private application files on shared hosting.
RewriteRule ^(\.git|\.agents|\.codex|app|config|database|storage|vendor|vexogen-erp)(/|$) - [F,L]
RewriteRule ^(\.env|composer\.(json|lock)|composer\.phar|README\.md)$ - [F,L]

# Allow one-time setup scripts at project root.
RewriteRule ^(install|backup)\.php$ - [L]

# Serve real public assets when the document root is the project root.
RewriteCond %{REQUEST_URI} !/public/
RewriteRule ^server-check\.php$ public/server-check.php [L]
RewriteCond %{REQUEST_URI} !/public/
RewriteRule ^diagnose\.php$ public/diagnose.php [L]
RewriteCond %{REQUEST_URI} !/public/
RewriteRule ^(.+\.(?:css|js|png|jpe?g|gif|webp|svg|ico|woff2?|ttf|map))$ public/$1 [L]

# Send application routes directly to the public entry point.
RewriteCond %{REQUEST_URI} !/public/
RewriteRule ^(.*)$ public/index.php [QSA,L]
